# =============================================================================
# Mutual Fund Analyzer — Backend Environment Variables
# Copy this file to .env and edit as needed.
# =============================================================================

# --- Database ---
# /data is the Docker volume mount point (see docker-compose volumes).
# Do NOT change this path when running via Docker.
DATABASE_URL=sqlite:////data/mfa.db

# --- Logging ---
# Use DEBUG for development, INFO or WARNING for production.
LOG_LEVEL=INFO

# --- CORS ---
# Set this to the URL users open in their browser to reach the app.
# - Local only:       http://localhost:3001
# - LAN / remote:    http://<remote-machine-ip>:3001  (e.g. http://192.168.1.50:3001)
# - Custom domain:   https://mfa.yourdomain.com
# Multiple origins: comma-separated, no spaces.
CORS_ORIGINS=http://localhost:3001
