# ─── Backend ──────────────────────────────────────────────────────────────────
# Path to the SQLite database (inside the Docker named volume)
DATABASE_URL=sqlite:////data/mfa.db
LOG_LEVEL=DEBUG
# Comma-separated list of allowed CORS origins
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001
FUND_DAAS_API_KEY=sb_publishable_... # Required for Fund Intelligence DaaS integration

# ─── Frontend ─────────────────────────────────────────────────────────────────
# Only needed if you override the Next.js API rewrite target
# NEXT_PUBLIC_API_URL=http://backend:8000/api
