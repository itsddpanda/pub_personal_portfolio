# ─── Backend ──────────────────────────────────────────────────────────────────
# Docker Container Timezone (E.g. Asia/Kolkata, America/New_York, Europe/London)
TZ=Asia/Kolkata

# Path to the SQLite database (inside the Docker named volume)
DATABASE_URL=sqlite:////data/mfa.db
LOG_LEVEL=INFO
# Comma-separated list of allowed CORS origins
CORS_ORIGINS=http://127.0.0.1:3001,http://localhost:3001

# ─── Frontend ─────────────────────────────────────────────────────────────────
# Only needed if you override the Next.js API rewrite target
# NEXT_PUBLIC_API_URL=http://backend:8000/api
